# SentinelDesk — copy to .env and adjust for local development
# cp .env.example .env

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=local

# -----------------------------------------------------------------------------
# PostgreSQL (docker compose service: postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentineldesk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Used by FastAPI / Alembic (SENT-102+)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentineldesk
DATABASE_URL_SYNC=postgresql://sentinel:sentinel@localhost:5432/sentineldesk

# -----------------------------------------------------------------------------
# Redis (docker compose service: redis)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Celery (SENT-203+)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# MailHog (docker compose service: mailhog)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
MAILHOG_UI_URL=http://localhost:8025

# -----------------------------------------------------------------------------
# API / security (SENT-104+)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
JWT_SECRET=change-me-use-long-random-string-in-real-env
JWT_EXPIRE_HOURS=8

# Service ingest key (SENT-202+)
INGEST_API_KEY=dev-ingest-key-change-in-prod

# -----------------------------------------------------------------------------
# Frontend (SENT-106+)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Webhooks (SENT-701+)
# -----------------------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=dev-webhook-secret

# -----------------------------------------------------------------------------
# Optional local overrides (future services)
# -----------------------------------------------------------------------------
# MOCK_SIEM_PORT=8088
# INTEL_EMBED_PORT=8090
